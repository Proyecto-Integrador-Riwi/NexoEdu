# backend/.env.example  — copia como ".env" y completa (NUNCA subas el .env real).

# --- Base de datos ---
# Conexión a Supabase / Postgres gestionado (se usa cuando USE_LOCAL_DB=false)
SUPABASE_DB_URL=postgresql://usuario:password@host:puerto/postgres

PORT=3000

# --- JWT ---
JWT_SECRET=secreto_largo_y_aleatorio
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=otro_secreto_largo_y_aleatorio
JWT_REFRESH_EXPIRES_IN=7d

# --- Producción / despliegue ---
# NODE_ENV=production activa cookies cross-site (sameSite:none + secure).
NODE_ENV=development
# URL del frontend desplegado (Vercel), para CORS. En local se permite
# http://localhost:5173 automáticamente.
FRONTEND_URL=https://tu-frontend.vercel.app

# --- Base de datos local (desarrollo) ---
# Si USE_LOCAL_DB=true, se usan estas variables en vez de SUPABASE_DB_URL.
USE_LOCAL_DB=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=riwi_local
DB_USER=postgres
DB_PASSWORD=tu_password_local
